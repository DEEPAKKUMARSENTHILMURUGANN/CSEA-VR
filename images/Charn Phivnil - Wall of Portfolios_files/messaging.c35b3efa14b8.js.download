  // messaging.js
(() => {
  // Ensure CoreUtils is loaded
  if (!window.CoreUtils) {
    console.error('CoreUtils not loaded! Make sure core.js is loaded before messaging.js');
    // Export a no-op init to prevent errors
    window.MessagingApp = { init: () => console.warn('MessagingApp: CoreUtils not available') };
    return;
  }
  const { qs, qsa, escapeHtml, timeAgo, timeAgoShort, debounce, getCookie } = window.CoreUtils;
  
  // Helper to get static asset URLs (works in both dev and production)
  const STATIC_URL = window.STATIC_URL || '/static/';
  const getStaticUrl = (path) => `${STATIC_URL}${path}`;
  
  // Common static assets
  const STATIC_ASSETS = {
    defaultAvatar: getStaticUrl('images/defaultavatar.svg'),
    emojiIcon: getStaticUrl('images/emoji.svg'),
    docsIcon: getStaticUrl('images/docs.svg'),
  };
  
  // Validate required functions
  if (!qs || !qsa || !escapeHtml || !timeAgo || !timeAgoShort || !debounce || !getCookie) {
    console.error('Required functions missing from CoreUtils:', { qs, qsa, escapeHtml, timeAgo, timeAgoShort, debounce, getCookie });
    // Export a no-op init to prevent errors
    window.MessagingApp = { init: () => console.warn('MessagingApp: Required functions missing from CoreUtils') };
    return;
  }
    let currentConversationId = null;
    let currentOtherUser = null;
    let currentIsRequest = false;
    let selectedFile = null;
    let typingTimeout = null;
    let selectedUserForNewChat = null;
    
    // Pagination state
    let hasMoreMessages = false;
    let oldestMessageId = null;
    let isLoadingMoreMessages = false;
    const MESSAGES_PER_PAGE = 25;
    
    // Tab state
    let currentTab = 'inbox'; // 'inbox' or 'requests'
    let inboxSearchQuery = ''; // Search query for filtering conversations
    
    // Browser notification state
    let isPageVisible = true;
    let notificationPermission = Notification.permission;
    
    // WebSocket connection
    let chatSocket = null;
    let reconnectAttempts = 0;
    const MAX_RECONNECT_ATTEMPTS = 5;
    const RECONNECT_DELAY = 3000;
    let pingInterval = null;
    let otherUserTypingTimeout = null; // Auto-hide typing indicator

    // Helper to get CSRF token
    function getCSRFToken() {
      return getCookie('csrftoken');
    }
    
    // ===== WebSocket Connection Management =====
    function connectWebSocket() {
      if (chatSocket && chatSocket.readyState === WebSocket.OPEN) {
        return; // Already connected
      }
      
      const protocol = window.location.protocol === 'https:' ? 'wss:' : 'ws:';
      const wsUrl = `${protocol}//${window.location.host}/ws/chat/`;
      
      chatSocket = new WebSocket(wsUrl);
      
      chatSocket.onopen = function(e) {
        reconnectAttempts = 0;
        
        // Start ping interval to keep connection alive
        startPingInterval();
        
        // If we have an active conversation, rejoin it
        if (currentConversationId) {
          joinConversation(currentConversationId);
        }
      };
      
      chatSocket.onmessage = function(e) {
        const data = JSON.parse(e.data);
        handleWebSocketMessage(data);
      };
      
      chatSocket.onclose = function(e) {
        stopPingInterval();
        
        // Attempt to reconnect
        if (reconnectAttempts < MAX_RECONNECT_ATTEMPTS) {
          reconnectAttempts++;
          setTimeout(connectWebSocket, RECONNECT_DELAY);
        }
      };
      
      chatSocket.onerror = function(error) {
        console.error('WebSocket error:', error);
      };
    }
    
    function disconnectWebSocket() {
      stopPingInterval();
      if (chatSocket) {
        chatSocket.close();
        chatSocket = null;
      }
    }
    
    function startPingInterval() {
      stopPingInterval();
      pingInterval = setInterval(() => {
        if (chatSocket && chatSocket.readyState === WebSocket.OPEN) {
          chatSocket.send(JSON.stringify({ type: 'ping' }));
        }
      }, 30000); // Ping every 30 seconds
    }
    
    function stopPingInterval() {
      if (pingInterval) {
        clearInterval(pingInterval);
        pingInterval = null;
      }
    }
    
    function sendWebSocketMessage(data) {
      if (chatSocket && chatSocket.readyState === WebSocket.OPEN) {
        chatSocket.send(JSON.stringify(data));
      } else {
        console.warn('WebSocket not connected, attempting to reconnect...');
        connectWebSocket();
      }
    }
    
    function joinConversation(conversationId) {
      sendWebSocketMessage({
        type: 'join_conversation',
        conversation_id: conversationId
      });
    }
    
    function leaveConversation() {
      if (currentConversationId) {
        sendWebSocketMessage({
          type: 'leave_conversation',
          conversation_id: currentConversationId
        });
      }
    }
    
    // Handle incoming WebSocket messages
    function handleWebSocketMessage(data) {
      switch (data.type) {
        case 'connection_established':
          break;
          
        case 'joined_conversation':
          break;
          
        case 'new_message':
          handleNewMessage(data.message);
          break;
          
        case 'conversation_update':
          handleConversationUpdate(data);
          break;
          
        case 'typing':
          handleTypingIndicator(data);
          break;
          
        case 'messages_read':
          handleMessagesRead(data);
          break;
          
        case 'reaction_update':
          handleReactionUpdate(data);
          break;
          
        case 'user_joined':
          break;
          
        case 'user_left':
          break;
          
        case 'presence_update':
          handlePresenceUpdate(data);
          break;
          
        case 'notification':
          handleNotification(data);
          break;
          
        case 'badge_update':
          // Update navbar badge counts
          if (data.message_count !== undefined && window.updateMessageBadge) {
            window.updateMessageBadge(data.message_count);
          }
          break;
          
        case 'pong':
          // Keep-alive response received
          break;
          
        case 'error':
          console.error('WebSocket error:', data.message);
          break;
          
        default:
          break;
      }
    }
    
    // Handle notifications (new requests, request accepted, etc.)
    function handleNotification(data) {
      switch (data.notification_type) {
        case 'new_request':
          // Update request badge count
          loadRequestCount();
          // Show notification if on requests tab
          if (currentTab === 'requests') {
            loadConversations('requests');
          }
          // Show browser notification (only when page is not visible)
          if (data.data.from_user) {
            showBrowserNotification(
              'New message request',
              `${data.data.from_user.name} wants to chat with you`,
              null,
              () => {
                // Switch to requests tab
                const messagesTab = qs('#messages-tab');
                const requestsTab = qs('#requests-tab');
                if (messagesTab) messagesTab.classList.remove('active');
                if (requestsTab) requestsTab.classList.add('active');
                loadConversations('requests');
              },
              true // Check visibility - only show when tab is not visible
            );
          }
          break;
          
        case 'request_accepted':
          // Reload conversations to update status
          loadConversations();
          // If we're viewing this conversation, enable message input
          if (currentConversationId === data.data.conversation_id) {
            const messageInputSection = qs('#message-input-section');
            const requestPrompt = qs('#request-accept-prompt');
            if (messageInputSection) messageInputSection.style.display = 'block';
            if (requestPrompt) requestPrompt.style.display = 'none';
          }
          break;
          
        default:
          break;
      }
    }
    
    // Handle new message received via WebSocket
    // Request notification permission
    function requestNotificationPermission() {
      if (!('Notification' in window)) {
        return;
      }
      
      if (Notification.permission === 'default') {
        Notification.requestPermission().then(permission => {
          notificationPermission = permission;
        });
      }
    }
    
    // Show browser notification
    function showBrowserNotification(title, body, icon, onClick, checkVisibility = false) {
      if (!('Notification' in window)) {
        return;
      }
      if (Notification.permission !== 'granted') {
        return;
      }
      if (checkVisibility && isPageVisible) {
        return;
      }
      
      try {
        const notification = new Notification(title, {
          body: body,
          icon: icon || STATIC_ASSETS.defaultAvatar,
          tag: `wop-message-${Date.now()}`, // Unique tag for each notification
          requireInteraction: false,
        });
        
        notification.onclick = () => {
          window.focus();
          if (onClick) onClick();
          notification.close();
        };
        
        // Auto-close after 5 seconds
        setTimeout(() => notification.close(), 5000);
      } catch (error) {
        console.error('Error creating notification:', error);
      }
    }
    
    // Track page visibility
    function setupVisibilityTracking() {
      // Handle visibility change
      document.addEventListener('visibilitychange', () => {
        isPageVisible = !document.hidden;
      });
      
      // Handle window focus/blur
      window.addEventListener('focus', () => {
        isPageVisible = true;
      });
      
      window.addEventListener('blur', () => {
        isPageVisible = false;
      });
    }
    
    function handleNewMessage(message) {
      const messagesList = qs('#messages-list');
      const isCurrentConversation = message.conversation_id === currentConversationId;
      const isSent = message.sender.id === window.currentUserId;
      
      // Show browser notification if:
      // 1. Page is not visible (on another tab/window), OR
      // 2. Message is for a different conversation than the one currently open
      // AND the message is from someone else (not the current user)
      if (message.sender.id !== window.currentUserId && (!isPageVisible || !isCurrentConversation)) {
        const senderName = message.sender.name || message.sender.username;
        const messagePreview = message.content 
          ? message.content.substring(0, 50) + (message.content.length > 50 ? '...' : '')
          : '📎 Sent an attachment';
        
        showBrowserNotification(
          senderName,
          messagePreview,
          message.sender.avatar,
          () => {
            // Find and open the conversation when notification is clicked
            const chatItem = qs(`[data-conversation-id="${message.conversation_id}"]`);
            if (chatItem) {
              const otherUser = JSON.parse(chatItem.dataset.otherUser);
              const shortId = chatItem.dataset.shortId;
              openConversation(message.conversation_id, otherUser, shortId);
            }
          }
        );
      }
      
      // Check if this message is for the current conversation
      if (!isCurrentConversation) {
        // Update unread badge for this conversation in the list
        updateUnreadBadge(message.conversation_id, 1);
        // Update global message badge (in header)
        if (window.refreshMessageBadge) window.refreshMessageBadge();
        // Update conversation list to show new message preview
        loadConversations();
        return;
      }
      
      if (!messagesList) return;
      
      // Get the last message element to determine if this is a new block
      const lastMessageElement = messagesList.querySelector('.message-item:last-child');
      let previousMsg = null;
      
      if (lastMessageElement) {
        // Reconstruct previous message object from DOM for block detection
        const lastSenderId = parseInt(lastMessageElement.dataset.senderId);
        const lastMessageDate = lastMessageElement.dataset.messageDate;
        previousMsg = {
          sender: { id: lastSenderId },
          created_at: lastMessageDate
        };
      }
      
      // Check if this is the first message in the list
      const isFirstMessage = !lastMessageElement;
      
      // Use renderMessageHTML for consistency
      const messageHTML = renderMessageHTML(message, previousMsg, isFirstMessage);
      
      messagesList.insertAdjacentHTML('beforeend', messageHTML);
      
      // Scroll to bottom only if user is already near the bottom
      // This prevents interrupting user when they're reading older messages
      const chatMessages = qs('#chat-messages-container');
      if (chatMessages) {
        const shouldScroll = isNearBottom(chatMessages, 150);
        if (shouldScroll) {
          requestAnimationFrame(() => {
            chatMessages.scrollTop = chatMessages.scrollHeight;
          });
        }
      }
      
      // Attach event handlers to new message
      attachMessageEventHandlers();
      
      // Mark as read via WebSocket
      if (!isSent) {
        sendWebSocketMessage({
          type: 'mark_read',
          conversation_id: currentConversationId
        });
      }
      
      // Hide typing indicator and show status
      const typingIndicator = qs('#typing-indicator');
      const headerStatus = qs('#chat-header-status');
      if (typingIndicator) {
        typingIndicator.style.display = 'none';
      }
      if (headerStatus) {
        headerStatus.style.display = 'block';
      }
      
      // Update conversation list to show new message preview
      loadConversations();
    }
    
    // Handle conversation update (new message in other conversation)
    function handleConversationUpdate(data) {
      // Update unread badge for this conversation
      if (data.conversation_id && data.conversation_id !== currentConversationId) {
        updateUnreadBadge(data.conversation_id, 1);
      }
      // Refresh conversation list to show updated preview
      loadConversations();
    }
    
    // Update unread badge for a conversation
    function updateUnreadBadge(conversationId, increment) {
      const chatItem = qs(`[data-conversation-id="${conversationId}"]`);
      if (!chatItem) return;
      
      let badge = chatItem.querySelector('.unread-badge');
      
      if (increment > 0) {
        if (badge) {
          // Increment existing badge
          const currentCount = parseInt(badge.textContent) || 0;
          badge.textContent = currentCount + increment;
        } else {
          // Create new badge
          const container = chatItem.querySelector('.w-layout-hflex');
          if (container) {
            container.insertAdjacentHTML('beforeend', `<span class="unread-badge">${increment}</span>`);
          }
        }
      } else if (increment === 0 && badge) {
        // Clear badge
        badge.remove();
      }
    }
    
    // Clear unread badge for a conversation
    function clearUnreadBadge(conversationId) {
      const chatItem = qs(`[data-conversation-id="${conversationId}"]`);
      if (!chatItem) return;
      
      const badge = chatItem.querySelector('.unread-badge');
      if (badge) {
        badge.remove();
      }
    }
    
    // Handle typing indicator via WebSocket
    function handleTypingIndicator(data) {
      const typingIndicator = qs('#typing-indicator');
      const typingUserName = qs('#typing-user-name');
      const headerStatus = qs('#chat-header-status');
      
      if (!typingIndicator || !typingUserName) return;
      
      // Clear any existing auto-hide timeout
      if (otherUserTypingTimeout) {
        clearTimeout(otherUserTypingTimeout);
        otherUserTypingTimeout = null;
      }
      
      if (data.is_typing) {
        // Hide status, show typing
        if (headerStatus) headerStatus.style.display = 'none';
        typingUserName.textContent = 'Typing...';
        typingIndicator.style.display = 'flex';
        
        // Auto-hide after 5 seconds in case we miss the stop event
        otherUserTypingTimeout = setTimeout(() => {
          typingIndicator.style.display = 'none';
          if (headerStatus) headerStatus.style.display = 'block';
        }, 5000);
      } else {
        // Hide typing, show status
        typingIndicator.style.display = 'none';
        if (headerStatus) headerStatus.style.display = 'block';
      }
    }
    
    // Handle messages read notification
    function handleMessagesRead(data) {
      // Could update message read indicators here
    }
    
    // Handle reaction update via WebSocket
    function handleReactionUpdate(data) {
      const messageItem = qs(`[data-message-id="${data.message_id}"]`);
      if (!messageItem) return;
      
      const reactionsContainer = messageItem.querySelector('.message-reactions');
      if (!reactionsContainer) return;
      
      // Rebuild reactions HTML
      let reactionsHTML = '';
      if (data.reactions && Object.keys(data.reactions).length > 0) {
        Object.entries(data.reactions).forEach(([emoji, users]) => {
          const userReacted = users.some(u => u.user_id === window.currentUserId);
          reactionsHTML += `
            <button class="message-reaction-item ${userReacted ? 'user-reacted' : ''}"
                    data-message-id="${data.message_id}" data-reaction="${emoji}">
              <span>${emoji}</span>
              <span class="message-reaction-count">${users.length}</span>
            </button>
          `;
        });
      }
      
      reactionsContainer.innerHTML = reactionsHTML;
      
      // Reattach event handlers
      reactionsContainer.querySelectorAll('.message-reaction-item').forEach(item => {
        item.addEventListener('click', async (e) => {
          e.stopPropagation();
          const messageId = item.dataset.messageId;
          const reaction = item.dataset.reaction;
          await toggleReaction(messageId, reaction);
        });
      });
    }
    
    // Handle presence update
    function handlePresenceUpdate(data) {
      // Update online status in conversation list
      const chatListItems = qsa('.chat-list-item');
      chatListItems.forEach(item => {
        try {
          const otherUser = JSON.parse(item.dataset.otherUser);
          if (otherUser.id === data.user_id) {
            // Update the data attribute to keep it in sync
            otherUser.is_online = data.is_online;
            item.dataset.otherUser = JSON.stringify(otherUser);
            
            const imgContainer = item.querySelector('[style*="position: relative"]');
            if (!imgContainer) return;
            
            const onlineDot = imgContainer.querySelector('.online-status-dot');
            if (data.is_online && !onlineDot) {
              imgContainer.insertAdjacentHTML('beforeend', '<span class="online-status-dot"></span>');
            } else if (!data.is_online && onlineDot) {
              onlineDot.remove();
            }
          }
        } catch (e) {
          console.error('Error updating presence in list:', e);
        }
      });
      
      // Update header if viewing this user's conversation
      if (currentOtherUser && currentOtherUser.id === data.user_id) {
        // Update currentOtherUser object
        currentOtherUser.is_online = data.is_online;
        
        const headerStatus = qs('#chat-header-status');
        if (headerStatus) {
          headerStatus.textContent = data.is_online ? 'Online' : 'Offline';
        }
      }
    }
    
    // Send typing status via WebSocket
    function sendTypingStatus(isTyping) {
      if (!currentConversationId) return;
      sendWebSocketMessage({
        type: isTyping ? 'typing_start' : 'typing_stop',
        conversation_id: currentConversationId
      });
    }
    
    // Current conversation short_id for URL
    let currentShortId = null;
    
    // Update URL to reflect current conversation
    function updateUrl(shortId) {
      const newUrl = shortId ? `/inbox/${shortId}/` : '/inbox/';
      if (window.location.pathname !== newUrl) {
        window.history.pushState({ shortId }, '', newUrl);
      }
    }

    // Using timeAgo from CoreUtils (imported at top)
    
    // Format message time (HH:MM format) - DEPRECATED: No longer used, kept for reference
    function formatMessageTime(dateString) {
      const date = new Date(dateString);
      return date.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }

    // Format date divider (e.g., "21st Nov, 25" or "Today")
    function formatDateDivider(dateString) {
      const date = new Date(dateString);
      const now = new Date();
      const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
      const messageDate = new Date(date.getFullYear(), date.getMonth(), date.getDate());
      
      // Check if it's today
      if (messageDate.getTime() === today.getTime()) {
        return 'Today';
      }
      
      // Check if it's yesterday
      const yesterday = new Date(today);
      yesterday.setDate(yesterday.getDate() - 1);
      if (messageDate.getTime() === yesterday.getTime()) {
        return 'Yesterday';
      }
      
      // Format as "21st Nov, 25"
      const day = date.getDate();
      const month = date.toLocaleDateString('en-US', { month: 'short' });
      const year = date.getFullYear().toString().slice(-2);
      
      // Add ordinal suffix
      const ordinal = (n) => {
        const s = ['th', 'st', 'nd', 'rd'];
        const v = n % 100;
        return n + (s[(v - 20) % 10] || s[v] || s[0]);
      };
      
      return `${ordinal(day)} ${month}, ${year}`;
    }

    // Helper function to check if two dates are on the same day
    function isSameDay(date1, date2) {
      if (!date1 || !date2) return false;
      const d1 = new Date(date1);
      const d2 = new Date(date2);
      return d1.getFullYear() === d2.getFullYear() &&
             d1.getMonth() === d2.getMonth() &&
             d1.getDate() === d2.getDate();
    }

    // Check if a new message block should start
    // A new block starts when: no previous message, different sender, or different date
    function isNewMessageBlock(msg, previousMsg) {
      if (!previousMsg) return true; // First message always starts a new block
      if (msg.sender.id !== previousMsg.sender.id) return true; // Different sender
      if (!isSameDay(msg.created_at, previousMsg.created_at)) return true; // Different date
      return false; // Same sender, same day = same block
    }

    // Format file size
    function formatFileSize(bytes) {
      if (bytes < 1024) return bytes + ' B';
      if (bytes < 1048576) return (bytes / 1024).toFixed(1) + ' KB';
      return (bytes / 1048576).toFixed(1) + ' MB';
    }

    // Using escapeHtml from CoreUtils (imported at top)

    // Load all conversations
    async function loadConversations(tab = null) {
      if (tab) currentTab = tab;
      
      try {
        const response = await fetch(`/api/conversations/?tab=${currentTab}`, {
          credentials: 'same-origin',
        });
        const data = await response.json();
        
        const chatList = qs('#chat-lists');
        const chatListEmpty = qs('#chat-list-empty');
        const emptyText = qs('#chat-list-empty p');
        
        if (!data.conversations || data.conversations.length === 0) {
          if (chatList) chatList.innerHTML = '';
          if (chatListEmpty) chatListEmpty.style.display = 'flex';
          if (emptyText) {
            emptyText.textContent = currentTab === 'requests' 
              ? 'No message requests.' 
              : 'No conversations yet.';
          }
          return;
        }
        
        if (chatListEmpty) chatListEmpty.style.display = 'none';
        
        if (chatList) {
          chatList.innerHTML = data.conversations.map(conv => {
            const lastMsg = conv.last_message;
            let lastMsgText = 'No messages yet';
            let lastMsgTime = '';
            
            if (lastMsg) {
              const isSentByMe = lastMsg.sender_id === window.currentUserId;
              const prefix = isSentByMe ? 'You: ' : '';
              const msgContent = lastMsg.has_file ? '📎 File attachment' : 
                (lastMsg.content || '').substring(0, 40);
              lastMsgText = prefix + msgContent;
              lastMsgTime = lastMsg.created_at ? timeAgoShort(lastMsg.created_at) : '';
            }
            
            const unreadBadge = conv.unread_count > 0 ? 
              `<span class="unread-badge">${conv.unread_count}</span>` : '';
            
            const onlineIndicator = conv.other_user.is_online ? 
              '<span class="online-status-dot"></span>' : '';
            
            // Show accept/reject buttons for incoming requests
            const requestActions = conv.is_request ? `
              <div class="request-actions">
                <button class="request-btn request-btn-accept" data-conversation-id="${conv.id}" data-action="accept">Accept</button>
                <button class="request-btn request-btn-reject" data-conversation-id="${conv.id}" data-action="reject">Reject</button>
              </div>
            ` : '';
            
            return `
              <div class="chat-list-item w100 px-6 py-3 ${currentConversationId === conv.id ? 'active' : ''}" 
                   data-conversation-id="${conv.id}"
                   data-short-id="${conv.short_id}"
                   data-status="${conv.status}"
                   data-is-request="${conv.is_request}"
                   data-other-user='${JSON.stringify(conv.other_user).replace(/'/g, '&apos;')}'>
                <div class="w-layout-hflex alignc gap16" style="overflow: hidden;">
                  <div style="position: relative; flex-shrink: 0;">
                    <img src="${conv.other_user.avatar || STATIC_ASSETS.defaultAvatar}" 
                         alt="Profile" class="dp56">
                    ${onlineIndicator}
                  </div>
                  <div class="w-layout-vflex gap4" style="min-width: 0; overflow: hidden; flex: 1;">
                    <div class="w-layout-hflex alignc w100 gap4">
                      <h3 class="lxl2 text-grey300" style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; text-transform: capitalize;">${escapeHtml(conv.other_user.name)}</h3>
                      <span class="p1 text-grey200">.</span>
                      ${lastMsgTime ? `<span class="conv-time p1 text-grey200">${lastMsgTime}</span>` : ''}
                    </div>
                    <div class="w-layout-hflex alignc gap8 w100">
                      <p class="p1 text-grey200 shrink" style="flex: 1;">${escapeHtml(lastMsgText)}</p>
                      ${unreadBadge}
                    </div>
                  </div>
                </div>
              </div>
            `;
          }).join('');
          
          // Attach click handlers for conversations
          qsa('.chat-list-item').forEach(item => {
            item.addEventListener('click', (e) => {
              // Don't open if clicking on action buttons
              if (e.target.closest('.request-actions')) return;
              
              const conversationId = parseInt(item.dataset.conversationId);
              const shortId = item.dataset.shortId;
              const otherUser = JSON.parse(item.dataset.otherUser);
              const isRequest = item.dataset.isRequest === 'true';
              
              // For requests, open but don't show message input until accepted
              openConversation(conversationId, otherUser, shortId, isRequest);
            });
          });
          
          // Attach click handlers for accept/reject buttons
          qsa('.request-btn-accept').forEach(btn => {
            btn.addEventListener('click', (e) => {
              e.stopPropagation();
              const conversationId = btn.dataset.conversationId;
              handleRequestAction(conversationId, 'accept');
            });
          });
          
          qsa('.request-btn-reject').forEach(btn => {
            btn.addEventListener('click', (e) => {
              e.stopPropagation();
              const conversationId = btn.dataset.conversationId;
              handleRequestAction(conversationId, 'reject');
            });
          });
        }
      } catch (error) {
        console.error('Error loading conversations:', error);
      }
    }
    
    // Handle accept/reject request
    async function handleRequestAction(conversationId, action) {
      try {
        const response = await fetch(`/api/conversations/${conversationId}/${action}/`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': getCSRFToken(),
          },
          credentials: 'same-origin',
        });
        
        const data = await response.json();
        
        if (data.success) {
          // Update request count
          await loadRequestCount();
          
          if (action === 'accept') {
            // Switch to Messages tab
            const messagesTab = qs('#messages-tab');
            const requestsTab = qs('#requests-tab');
            if (messagesTab) messagesTab.classList.add('active');
            if (requestsTab) requestsTab.classList.remove('active');
            
            // Load inbox conversations
            await loadConversations('inbox');
            
            // Enable messaging for current conversation
            if (currentConversationId === parseInt(conversationId)) {
              currentIsRequest = false; // Update request status
              const messageInputSection = qs('#message-input-section');
              const requestPrompt = qs('#request-accept-prompt');
              const sayHelloSection = qs('.say-hello-section');
              if (messageInputSection) messageInputSection.style.display = 'block';
              if (requestPrompt) requestPrompt.style.display = 'none';
              if (sayHelloSection) sayHelloSection.style.display = 'none';
            }
          } else {
            // For reject, stay on requests tab and reload
            await loadConversations();
          }
        } else {
          console.error('Request action failed:', data.error);
        }
      } catch (error) {
        console.error('Error handling request action:', error);
      }
    }
    
    // Load request count for badge
    async function loadRequestCount() {
      try {
        const response = await fetch('/api/requests/count/', {
          credentials: 'same-origin',
        });
        const data = await response.json();
        
        const badge = qs('#request-badge');
        if (badge) {
          if (data.count > 0) {
            badge.textContent = `${data.count}`;
            badge.style.display = 'inline-block';
          } else {
            badge.style.display = 'none';
          }
        }
      } catch (error) {
        console.error('Error loading request count:', error);
      }
    }
    
    // Filter conversations and search for new users
    async function filterConversations(query) {
      inboxSearchQuery = query.toLowerCase().trim();
      const chatList = qs('#chat-lists');
      const chatItems = qsa('.chat-list-item');
      const chatListEmpty = qs('#chat-list-empty');
      
      // Filter existing conversations
      let visibleConversations = 0;
      
      chatItems.forEach(item => {
        const otherUser = JSON.parse(item.dataset.otherUser || '{}');
        
        const name = (otherUser.name || '').toLowerCase();
        const username = (otherUser.username || '').toLowerCase();
        
        // Check if name or username matches the query
        const matches = !inboxSearchQuery || 
          name.includes(inboxSearchQuery) || 
          username.includes(inboxSearchQuery);
        
        if (matches) {
          item.style.display = '';
          visibleConversations++;
        } else {
          item.style.display = 'none';
        }
      });
      
      // Show/hide empty state
      if (visibleConversations === 0) {
        if (chatListEmpty) chatListEmpty.style.display = 'flex';
        const emptyText = qs('#chat-list-empty p');
        if (emptyText) {
          if (inboxSearchQuery) {
            emptyText.textContent = 'No matching conversations.';
          } else {
            emptyText.textContent = currentTab === 'requests' 
              ? 'No message requests.' 
              : 'No conversations yet.';
          }
        }
      } else {
        if (chatListEmpty) chatListEmpty.style.display = 'none';
      }
    }
    
    // Start a new conversation with a user from search results
    async function startNewConversationWithUser(user) {
      // Store the selected user
      selectedUserForNewChat = user;
      
      // Clear the search input
      const searchInput = qs('#inboxSearchInput');
      if (searchInput) searchInput.value = '';
      inboxSearchQuery = '';
      
      // Show all conversations again
      qsa('.chat-list-item').forEach(item => {
        item.style.display = '';
      });
      
      // Check if a conversation already exists with this user
      const existingConversation = qsa('.chat-list-item').find(item => {
        try {
          const otherUser = JSON.parse(item.dataset.otherUser);
          return otherUser.id === user.id;
        } catch (e) {
          return false;
        }
      });
      
      if (existingConversation) {
        // Conversation exists - open it instead of showing say-hello-section
        const conversationId = parseInt(existingConversation.dataset.conversationId);
        const shortId = existingConversation.dataset.shortId;
        const otherUser = JSON.parse(existingConversation.dataset.otherUser);
        const isRequest = existingConversation.dataset.isRequest === 'true';
        
        await openConversation(conversationId, otherUser, shortId, isRequest);
        selectedUserForNewChat = null; // Clear since we're opening existing conversation
        return;
      }
      
      // No existing conversation - show chat-active-state with say-hello-section
      const instructionState = qs('#instruction-state');
      const chatActiveState = qs('.chat-active-state');
      const sayHelloSection = qs('.say-hello-section');
      const messageInputSection = qs('#message-input-section');
      
      if (instructionState) instructionState.style.display = 'none';
      if (chatActiveState) chatActiveState.style.display = 'flex';
      if (sayHelloSection) sayHelloSection.style.display = 'flex';
      if (messageInputSection) messageInputSection.style.display = 'none';
      
      // Mobile: show chat panel, hide list
      const listChatWindow = qs('.list_chat_window');
      const rightContent = qs('.right_content');
      if (window.innerWidth <= 991) {
        if (listChatWindow) listChatWindow.classList.add('hidden');
        if (rightContent) rightContent.classList.add('active');
      }
      
      // Update header with selected user info
      const headerAvatar = qs('.chat-header-avatar');
      const headerName = qs('.chat-header-name');
      const headerStatus = qs('#chat-header-status');
      
      if (headerAvatar) headerAvatar.src = user.avatar || STATIC_ASSETS.defaultAvatar;
      if (headerName) headerName.textContent = user.name;
      if (headerStatus) {
        const status = user.is_online ? 'Online' : 
          user.last_seen ? `Last seen ${timeAgo(user.last_seen)}` : '';
        headerStatus.textContent = status;
      }
    }

    // Open a conversation
    async function openConversation(conversationId, otherUser, shortId, isRequest = false) {
      // Leave previous conversation via WebSocket
      if (currentConversationId && currentConversationId !== conversationId) {
        leaveConversation();
      }
      
      currentConversationId = conversationId;
      currentOtherUser = otherUser;
      currentShortId = shortId;
      currentIsRequest = isRequest;
      
      // Update URL to reflect current conversation (using short_id)
      updateUrl(shortId);
      
      // Mobile: Show chat window, hide chat list
      const listChatWindow = qs('.list_chat_window');
      const rightContent = qs('.right_content');
      if (window.innerWidth <= 991) {
        if (listChatWindow) listChatWindow.classList.add('hidden');
        if (rightContent) rightContent.classList.add('active');
      }
      
      // Update UI
      const instructionState = qs('#instruction-state');
      const chatActiveState = qs('.chat-active-state');
      const sayHelloSection = qs('.say-hello-section');
      const messageInputSection = qs('#message-input-section');
      const requestPrompt = qs('#request-accept-prompt');
      
      if (instructionState) instructionState.style.display = 'none';
      if (chatActiveState) chatActiveState.style.display = 'flex';
      
      // Don't set say-hello-section or message input visibility here - let loadMessages handle it based on message count
      // This ensures empty conversations show the say-hello-section
      
      // Show message input only if not a pending request (needs acceptance)
      if (isRequest) {
        if (messageInputSection) messageInputSection.style.display = 'none';
        if (requestPrompt) requestPrompt.style.display = 'flex';
        if (sayHelloSection) sayHelloSection.style.display = 'none';
      } else {
        // Don't show input yet - let loadMessages decide based on message count
        // It will show say-hello-section if no messages, or input if messages exist
        if (messageInputSection) {
          messageInputSection.style.display = 'none';
        }
        if (requestPrompt) requestPrompt.style.display = 'none';
      }
      
      // Update header
      const headerAvatar = qs('.chat-header-avatar');
      const headerName = qs('.chat-header-name');
      const headerStatus = qs('#chat-header-status');
      
      if (headerAvatar) headerAvatar.src = otherUser.avatar || STATIC_ASSETS.defaultAvatar;
      if (headerName) headerName.textContent = otherUser.name;
      if (headerStatus) {
        const status = otherUser.is_online ? 'Online' : 
          otherUser.last_seen ? `Last seen ${timeAgo(otherUser.last_seen)}` : '';
        headerStatus.textContent = status;
      }
      
      // Mark active in list and clear unread badge
      qsa('.chat-list-item').forEach(item => item.classList.remove('active'));
      const activeItem = qs(`[data-conversation-id="${conversationId}"]`);
      if (activeItem) {
        activeItem.classList.add('active');
        // Clear unread badge for this conversation
        const unreadBadge = activeItem.querySelector('.unread-badge');
        if (unreadBadge) {
          unreadBadge.remove();
        }
      }
      
      // Load messages (force scroll when opening conversation)
      await loadMessages(conversationId, true);
      
      // Join conversation via WebSocket for real-time updates
      joinConversation(conversationId);
      
      // Mark messages as read via WebSocket
      sendWebSocketMessage({
        type: 'mark_read',
        conversation_id: conversationId
      });
    }

    // Check if user is near bottom of chat
    function isNearBottom(container, threshold = 100) {
      if (!container) return false;
      const scrollTop = container.scrollTop;
      const scrollHeight = container.scrollHeight;
      const clientHeight = container.clientHeight;
      return (scrollHeight - scrollTop - clientHeight) <= threshold;
    }
    // Load messages for a conversation
    async function loadMessages(conversationId, forceScroll = false) {
      try {
        hasMoreMessages = false;
        oldestMessageId = null;
        isLoadingMoreMessages = false;
        const chatMessages = qs('#chat-messages-container');
        const wasNearBottom = forceScroll || (chatMessages && isNearBottom(chatMessages));
        
        const response = await fetch(`/api/conversations/${conversationId}/messages/?limit=${MESSAGES_PER_PAGE}`, {
          credentials: 'same-origin',
        });
        const data = await response.json();
        
        // Update pagination state
        hasMoreMessages = data.has_more;
        oldestMessageId = data.oldest_id;
        
        const messagesList = qs('#messages-list');
        if (!messagesList) return;
        
        // Render messages with date dividers
        let messagesHTML = '';
        let previousMsg = null;
        data.messages.forEach((msg, index) => {
          const isFirstMessage = index === 0;
          messagesHTML += renderMessageHTML(msg, previousMsg, isFirstMessage);
          previousMsg = msg;
        });
        
        messagesList.innerHTML = messagesHTML;
        
        // Update say-hello-section visibility based on whether there are messages
        const sayHelloSection = qs('.say-hello-section');
        const messageInputSection = qs('#message-input-section');
        const requestPrompt = qs('#request-accept-prompt');
        const hasMessages = data.messages && data.messages.length > 0;
        
        // For pending requests, always hide input and show request prompt
        if (currentIsRequest) {
          if (sayHelloSection) sayHelloSection.style.display = 'none';
          if (messageInputSection) messageInputSection.style.display = 'none';
          if (requestPrompt) requestPrompt.style.display = 'flex';
        } else if (sayHelloSection && messageInputSection) {
          if (hasMessages) {
            // Hide say-hello-section if there are messages (conversation has started)
            sayHelloSection.style.display = 'none';
            messageInputSection.style.display = 'block';
            if (requestPrompt) requestPrompt.style.display = 'none';
          } else {
            // No messages yet - show say-hello-section for empty conversations
            sayHelloSection.style.display = 'flex';
            messageInputSection.style.display = 'none';
            if (requestPrompt) requestPrompt.style.display = 'none';
          }
        }
        
        // Clear selectedUserForNewChat after determining visibility
        // (we've already used it to determine if say-hello-section should show)
        if (selectedUserForNewChat) {
          selectedUserForNewChat = null;
        }
        
        // Add "load more" indicator if there are more messages
        if (hasMoreMessages) {
          messagesList.insertAdjacentHTML('afterbegin', `
            <div id="load-more-messages" class="load-more-indicator">
              <span class="load-more-text">Scroll up for older messages</span>
            </div>
          `);
        }
        
        // Always scroll to bottom on initial load (when opening conversation)
        // Use double requestAnimationFrame to ensure DOM is fully rendered
        if (chatMessages) {
          requestAnimationFrame(() => {
            requestAnimationFrame(() => {
              if (forceScroll || wasNearBottom) {
                chatMessages.scrollTop = chatMessages.scrollHeight;
              }
            });
          });
          
          // Set up scroll listener for loading more messages
          chatMessages.removeEventListener('scroll', handleMessagesScroll);
          chatMessages.addEventListener('scroll', handleMessagesScroll);
        }
        
        // Attach event handlers
        attachMessageEventHandlers();
        
      } catch (error) {
        console.error('Error loading messages:', error);
      }
    }
    
    // Handle scroll to load more messages
    function handleMessagesScroll(e) {
      const container = e.target;
      
      // Check if scrolled near the top (within 100px)
      if (container.scrollTop < 100 && hasMoreMessages && !isLoadingMoreMessages && oldestMessageId) {
        loadMoreMessages();
      }
    }
    
    // Load older messages (pagination)
    async function loadMoreMessages() {
      if (isLoadingMoreMessages || !hasMoreMessages || !currentConversationId || !oldestMessageId) {
        return;
      }
      
      isLoadingMoreMessages = true;
      
      // Show loading indicator
      const loadMoreIndicator = qs('#load-more-messages');
      if (loadMoreIndicator) {
        loadMoreIndicator.innerHTML = '<span class="loading-spinner"></span> Loading...';
      }
      
      try {
        const response = await fetch(
          `/api/conversations/${currentConversationId}/messages/?limit=${MESSAGES_PER_PAGE}&before_id=${oldestMessageId}`,
          { credentials: 'same-origin' }
        );
        const data = await response.json();
        
        // Update pagination state
        hasMoreMessages = data.has_more;
        oldestMessageId = data.oldest_id;
        
        const messagesList = qs('#messages-list');
        const chatMessages = qs('#chat-messages-container');
        if (!messagesList || !chatMessages) return;
        
        // Remember scroll position
        const previousScrollHeight = chatMessages.scrollHeight;
        
        // Remove old load-more indicator
        const oldIndicator = qs('#load-more-messages');
        if (oldIndicator) oldIndicator.remove();
        
        // Check if there are existing messages (to determine if first new message needs spacer)
        const firstExistingMessage = messagesList.querySelector('.message-item');
        const hasExistingMessages = !!firstExistingMessage;
        
        // Render messages with date dividers
        let messagesHTML = '';
        let previousMsg = null;
        data.messages.forEach((msg, index) => {
          // For pagination: first message is only "first" if there are no existing messages
          const isFirstMessage = index === 0 && !hasExistingMessages;
          messagesHTML += renderMessageHTML(msg, previousMsg, isFirstMessage);
          previousMsg = msg;
        });
        
        // Check if we need a date divider between new messages and existing messages
        if (firstExistingMessage && data.messages.length > 0) {
          const lastNewMessage = data.messages[data.messages.length - 1];
          const firstExistingDate = firstExistingMessage.dataset.messageDate;
          if (!firstExistingDate || !isSameDay(firstExistingDate, lastNewMessage.created_at)) {
            const dividerHTML = `
              
                <span class="message-date-text p1 text-grey200 py-2">${formatDateDivider(firstExistingDate)}</span>
             
            `;
            messagesHTML += dividerHTML;
          }
        }
        
        // Add new load-more indicator if more messages exist
        const newIndicator = hasMoreMessages ? `
          <div id="load-more-messages" class="load-more-indicator">
            <span class="load-more-text">Scroll up for older messages</span>
          </div>
        ` : '';
        
        messagesList.insertAdjacentHTML('afterbegin', newIndicator + messagesHTML);
        
        // Maintain scroll position (so user doesn't jump)
        chatMessages.scrollTop = chatMessages.scrollHeight - previousScrollHeight;
        
        // Attach event handlers to new messages
        attachMessageEventHandlers();
        
      } catch (error) {
        console.error('Error loading more messages:', error);
      } finally {
        isLoadingMoreMessages = false;
      }
    }
    
    // Render a single message to HTML (reusable for pagination)
    function renderMessageHTML(msg, previousMsg = null, isFirstMessage = false) {
      const isSent = msg.sender.id === window.currentUserId;
      const messageType = isSent ? 'sent' : 'received';
      const isNewBlock = isNewMessageBlock(msg, previousMsg);
      
      // Check if we need to add a date divider
      let dateDividerHTML = '';
      if (!previousMsg || !isSameDay(previousMsg.created_at, msg.created_at)) {
        dateDividerHTML = `
          
            <span class="message-date-text p1 text-grey200 py-2">${formatDateDivider(msg.created_at)}</span>
          
        `;
      }
      
      // Add spacer before new block (except for the very first message)
      const spacerHTML = isNewBlock && !isFirstMessage ? 
        '<div role="presentation" class="message-block-spacer"></div>' : '';
      
      // File attachment
      let fileHTML = '';
      if (msg.file_url) {
        if (msg.file_type === 'image') {
          fileHTML = `<img src="${msg.file_url}" alt="${escapeHtml(msg.file_name)}" class="message-file-thumbnail message-image-clickable" data-image-url="${msg.file_url}" data-image-name="${escapeHtml(msg.file_name || 'Image')}">`;
        } else {
          fileHTML = `
            <a href="${msg.file_url}" target="_blank" class="message-file-attachment">
              <img src="${STATIC_ASSETS.docsIcon}" alt="File" class="message-file-icon" style="width: 40px; height: 40px; padding: 8px; background-color: #fff; border-radius: 8px;">
              <div class="w-layout-vflex gap4">
                <p class="p1">${escapeHtml(msg.file_name)}</p>
              </div>
            </a>
          `;
        }
      }
      
      // Reactions - always include container for dynamic reactions
      let reactionsHTML = '<div class="message-reactions">';
      if (msg.reactions && Object.keys(msg.reactions).length > 0) {
        Object.entries(msg.reactions).forEach(([emoji, users]) => {
          const userReacted = users.some(u => u.user_id === window.currentUserId);
          reactionsHTML += `
            <button class="message-reaction-item ${userReacted ? 'user-reacted' : ''}"
                    data-message-id="${msg.id}" data-reaction="${emoji}">
              <span>${emoji}</span>
              <span class="message-reaction-count">${users.length}</span>
            </button>
          `;
        });
      }
      reactionsHTML += '</div>';
      
      // Ensure content is a string
      const messageContent = typeof msg.content === 'string' ? msg.content : 
        (msg.content ? JSON.stringify(msg.content) : '');
      
      // Profile picture: ONLY for received messages AND ONLY on first message of a block
      const showAvatar = !isSent && isNewBlock;
      const senderAvatar = msg.sender.avatar || STATIC_ASSETS.defaultAvatar;
      const profilePictureHTML = showAvatar ? `
        <img src="${senderAvatar}" alt="${escapeHtml(msg.sender.name || msg.sender.username)}" class="dp24sm" />
      ` : '';
      
      // Add class for messages without avatars (for CSS alignment)
      const noAvatarClass = !isSent && !showAvatar ? ' message-no-avatar' : '';
      
      return `
        ${dateDividerHTML}
        ${spacerHTML}
        <div class="message-item message-${messageType}${noAvatarClass}" data-message-id="${msg.id}" data-message-date="${msg.created_at}" data-sender-id="${msg.sender.id}">
          ${profilePictureHTML}
          <div class="message-bubble message-bubble-${messageType}">
            ${messageContent ? `<p class="message-text p1">${escapeHtml(messageContent)}</p>` : ''}
            ${fileHTML}
            ${reactionsHTML}
          </div>
          ${!isSent ? `
          <div class="message-actions">
            <button class="message-action-btn react-btn" data-message-id="${msg.id}">
              <span><img src="${STATIC_ASSETS.emojiIcon}" alt="React" style="width: 16px; height: 16px;"></span>
            </button>
          </div>
          ` : ''}
        </div>
      `;
    }

    // Attach event handlers to messages
    function attachMessageEventHandlers() {
      // React buttons
      qsa('.react-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          showReactionPicker(btn);
        });
      });
      
      // Reaction items (toggle)
      qsa('.message-reaction-item').forEach(item => {
        item.addEventListener('click', async (e) => {
          e.stopPropagation();
          const messageId = item.dataset.messageId;
          const reaction = item.dataset.reaction;
          await toggleReaction(messageId, reaction);
        });
      });
      
      // Image click to open modal
      qsa('.message-image-clickable').forEach(img => {
        if (!img.dataset.listenerAttached) {
          img.dataset.listenerAttached = 'true';
          img.addEventListener('click', (e) => {
            e.stopPropagation();
            openImageModal(img.dataset.imageUrl, img.dataset.imageName);
          });
        }
      });
    }
    
    // ===== Image Modal =====
    function openImageModal(imageUrl, imageName) {
      const modal = qs('#image-modal');
      const modalImg = qs('#image-modal-img');
      const modalCaption = qs('#image-modal-caption');
      
      if (!modal || !modalImg) return;
      
      modalImg.src = imageUrl;
      modalImg.alt = imageName || 'Image';
      if (modalCaption) {
        modalCaption.textContent = imageName || '';
      }
      
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden'; // Prevent background scroll
    }
    
    function closeImageModal() {
      const modal = qs('#image-modal');
      if (modal) {
        modal.style.display = 'none';
        document.body.style.overflow = ''; // Restore scroll
      }
    }
    
    // Initialize image modal
    function initImageModal() {
      const modal = qs('#image-modal');
      const closeBtn = qs('#image-modal-close');
      
      if (!modal) return;
      
      // Close on close button click
      if (closeBtn) {
        closeBtn.addEventListener('click', closeImageModal);
      }
      
      // Close on backdrop click
      modal.addEventListener('click', (e) => {
        if (e.target === modal) {
          closeImageModal();
        }
      });
      
      // Close on Escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && modal.style.display === 'flex') {
          closeImageModal();
        }
      });
    }

    // Show reaction picker
    function showReactionPicker(button) {
      const picker = qs('#reaction-picker');
      if (!picker) return;
      
      const messageId = button.dataset.messageId;
      picker.dataset.messageId = messageId;
      
      const rect = button.getBoundingClientRect();
      picker.style.top = `${rect.top - 60}px`;
      picker.style.left = `${rect.left}px`;
      picker.style.display = 'flex';
      
      // Close on outside click
      setTimeout(() => {
        document.addEventListener('click', closeReactionPicker, { once: true });
      }, 100);
    }

    function closeReactionPicker() {
      const picker = qs('#reaction-picker');
      if (picker) picker.style.display = 'none';
    }

    // Toggle reaction via WebSocket
    function toggleReaction(messageId, reaction) {
      sendWebSocketMessage({
        type: 'add_reaction',
        message_id: parseInt(messageId),
        reaction: reaction
      });
    }

    // Send message via WebSocket
    async function sendMessage() {
      const messageInput = qs('#messageInput');
      if (!messageInput) return;
      
      const content = messageInput.value.trim();
      
      if (!content && !selectedFile) return;
      if (!currentConversationId) return;
      
      // Upload file if selected (still needs HTTP for file upload)
      let fileUrl = null;
      let fileName = null;
      let fileType = null;
      
      if (selectedFile) {
        const uploadResult = await uploadFile(selectedFile);
        if (uploadResult) {
          fileUrl = uploadResult.file_url;
          fileName = selectedFile.name;
          fileType = selectedFile.type.startsWith('image/') ? 'image' : 'document';
        } else {
          console.error('File upload failed, not sending message');
          return; // Don't send message if file upload failed
        }
      }
      
      // Ensure we have either content or file
      if (!content && !fileUrl) {
        console.warn('No content or file to send');
        return;
      }
      
      // Send message via WebSocket
      sendWebSocketMessage({
        type: 'send_message',
        conversation_id: currentConversationId,
        content: content,
        file_url: fileUrl,
        file_name: fileName,
        file_type: fileType,
      });
      
      // Clear input immediately for better UX
      messageInput.value = '';
      // Reset textarea height
      messageInput.style.height = 'auto';
      clearFilePreview();
      
      // Stop typing indicator
      sendTypingStatus(false);
    }

    // Upload file to S3
    async function uploadFile(file) {
      try {
        const formData = new FormData();
        formData.append('file', file);
        // Upload file - backend handles S3 upload directly
        const urlResponse = await fetch('/api/s3/upload-url/', {
          method: 'POST',
          headers: {
            'X-CSRFToken': getCSRFToken(),
          },
          credentials: 'same-origin',
          body: formData
        });
        
        if (!urlResponse.ok) {
          console.error('File upload failed:', await urlResponse.text());
          return null;
        }
        
        const { file_url } = await urlResponse.json();
        
        // File is already uploaded by the backend, just return the URL
        return { file_url };
      } catch (error) {
        console.error('Error uploading file:', error);
        return null;
      }
    }

    // Handle file selection
    function handleFileSelect(e) {
      const file = e.target.files[0];
      if (!file) return;
      
      // Check file size (max 10MB)
      if (file.size > 10 * 1024 * 1024) {
        alert('File size must be less than 10MB');
        return;
      }
      
      selectedFile = file;
      showFilePreview(file);
    }

    // Show file preview
    function showFilePreview(file) {
      const previewSection = qs('#file-preview-section');
      const previewImg = qs('#file-preview-img');
      const previewName = qs('#file-preview-name');
      const previewSize = qs('#file-preview-size');
      
      if (!previewSection || !previewName || !previewSize) return;
      
      previewName.textContent = file.name;
      previewSize.textContent = formatFileSize(file.size);
      
      // Show image preview if it's an image
      if (file.type.startsWith('image/') && previewImg) {
        const reader = new FileReader();
        reader.onload = (e) => {
          previewImg.src = e.target.result;
          previewImg.style.display = 'block';
        };
        reader.readAsDataURL(file);
      } else if (previewImg) {
        previewImg.style.display = 'none';
      }
      
      previewSection.style.display = 'block';
    }

    // Clear file preview
    function clearFilePreview() {
      selectedFile = null;
      const previewSection = qs('#file-preview-section');
      const fileInput = qs('#fileInput');
      
      if (previewSection) previewSection.style.display = 'none';
      if (fileInput) fileInput.value = '';
    }

    // Update typing status via WebSocket
    function updateTypingStatus(isTyping) {
      sendTypingStatus(isTyping);
    }

    // Search users
    async function searchUsers(query) {
      const resultsContainer = qs('#user-search-results');
      const emptyState = qs('#user-search-empty'); // "no users found" state
      const initialState = qs('#user-search-initial'); // instructional empty state

      // For very short queries, show the instructional empty state instead of results
      if (query.length < 2) {
        if (resultsContainer) resultsContainer.innerHTML = '';
        if (emptyState) emptyState.style.display = 'none';
        if (initialState) initialState.style.display = 'flex';
        return;
      }
      
      // Hide instructional state once we have a real query
      if (initialState) initialState.style.display = 'none';

      try {
        const response = await fetch(`/api/users/search/?q=${encodeURIComponent(query)}`, {
          credentials: 'same-origin',
        });
        const data = await response.json();
        
        if (!resultsContainer || !emptyState) {
          return;
        }
        
        if (!data.users || data.users.length === 0) {
          resultsContainer.innerHTML = '';
          if (initialState) initialState.style.display = 'none';
          emptyState.style.display = 'flex';
          return;
        }
        
        emptyState.style.display = 'none';
        if (initialState) initialState.style.display = 'none';
        
        if (resultsContainer) {
          resultsContainer.innerHTML = data.users.map(user => `
            <div class="user-search-item w-layout-hflex gap16 w100 py-3 alignc" data-user-id="${user.id}" 
                 data-user='${JSON.stringify(user).replace(/'/g, '&apos;')}'>
              <img src="${user.avatar || STATIC_ASSETS.defaultAvatar}" 
                   alt="Profile" class="dp56">
              <div class="w-layout-vflex gap4">
                <h3 class="llg text-grey300 shrink">${escapeHtml(user.name)}</h3>
                ${user.title ? `<p class="lm3 text-grey200">${escapeHtml(user.title)}</p>` : ''}
              </div>
            </div>
          `).join('');
          
          // Attach click handlers (only for items in results container)
          qsa('.user-search-item', resultsContainer).forEach(item => {
            item.addEventListener('click', () => {
              const user = JSON.parse(item.dataset.user);
              selectUserForNewChat(user);
            });
          });
        }
      } catch (error) {
        console.error('Error searching users:', error);
      }
    }

    // Load and render suggested designers in the initial state
    async function loadSuggestedUsers() {
      const list = qs('#user-search-suggested-list');
      if (!list) return;
      list.innerHTML = '';
      try {
        const response = await fetch('/api/users/suggested/', { credentials: 'same-origin' });
        const data = await response.json();
        if (!data.users || data.users.length === 0) return;
        list.innerHTML = data.users.map(user => `
          <div class="user-search-item w-layout-hflex gap16 w100 py-3 alignc" data-user-id="${user.id}" 
               data-user='${JSON.stringify(user).replace(/'/g, '&apos;')}'>
            <img src="${user.avatar || STATIC_ASSETS.defaultAvatar}" 
                 alt="Profile" class="dp56">
            <div class="w-layout-vflex gap4">
              <h3 class="llg text-grey300 shrink">${escapeHtml(user.name)}</h3>
              ${user.title ? `<p class="lm3 text-grey200">${escapeHtml(user.title)}</p>` : ''}
            </div>
          </div>
        `).join('');
        qsa('.user-search-item', list).forEach(item => {
          item.addEventListener('click', () => {
            const user = JSON.parse(item.dataset.user);
            selectUserForNewChat(user);
          });
        });
      } catch (error) {
        console.error('Error loading suggested users:', error);
      }
    }

    // Select user for new chat
    function selectUserForNewChat(user) {
      selectedUserForNewChat = user;
      
      // Close user search modal
      const userSearchModal = qs('#user-search-modal');
      if (userSearchModal) userSearchModal.style.display = 'none';
      
      // Show chat-active-state with say-hello-section
      startNewConversationWithUser(user);
    }

    // Create new conversation
    async function createConversation(intent) {
      if (!selectedUserForNewChat) return;
      
      // Hide say-hello-section and show input immediately when button is clicked
      const sayHelloSection = qs('.say-hello-section');
      const messageInputSection = qs('#message-input-section');
      if (sayHelloSection) sayHelloSection.style.display = 'none';
      if (messageInputSection) messageInputSection.style.display = 'block';
      
      // Store user and clear selectedUserForNewChat immediately so loadMessages won't show say-hello-section
      const userToOpen = selectedUserForNewChat;
      selectedUserForNewChat = null;
      
      try {
        const response = await fetch('/api/conversations/create/', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRFToken': getCSRFToken(),
          },
          credentials: 'same-origin',
          body: JSON.stringify({
            other_user_id: userToOpen.id,
            intent: intent,
          }),
        });
        
        if (response.ok) {
          const data = await response.json();
          
          // Reload conversations and open the new one
          await loadConversations();
          await openConversation(data.conversation_id, userToOpen, data.short_id);
          
          // Re-ensure message input is visible after openConversation completes
          // (openConversation -> loadMessages may have shown say-hello-section for empty conversations)
          const sayHelloSectionAfter = qs('.say-hello-section');
          const messageInputSectionAfter = qs('#message-input-section');
          if (sayHelloSectionAfter) sayHelloSectionAfter.style.display = 'none';
          if (messageInputSectionAfter) messageInputSectionAfter.style.display = 'block';
          
          // Prepopulate message based on intent (only for new conversations)
          const messageInput = qs('#messageInput');
          if (messageInput && data.exists === false) {
            const intentMessages = {
              'portfolio-review': 'Hi!\n\nI came across your work and it really stood out.\nI’m currently refining my portfolio — sharing the link below in case you’re open to quick feedback:', 
              'guidance': 'Hi!\n\nI’m at a point in my design career where I’m thinking about next steps.\nI’d really appreciate any perspective or advice if you’re open to sharing.',
              'opportunities': 'Hi!\n\nI found your profile on Wall of Portfolios and really liked your work.\nI’d love to connect and explore potential opportunities if you’re open to a conversation.',
            };
            messageInput.value = intentMessages[intent] || '';
            
            // Trigger auto-grow to show all lines (use setTimeout to ensure DOM is updated)
            setTimeout(() => {
              messageInput.style.height = 'auto';
              const scrollHeight = messageInput.scrollHeight;
              const maxHeight = 160; // Max height in pixels
              const newHeight = Math.min(scrollHeight, maxHeight);
              messageInput.style.height = newHeight + 'px';
              // Enable scrolling when content exceeds max height
              messageInput.style.overflowY = scrollHeight > maxHeight ? 'auto' : 'hidden';
            }, 0);
          }
        }
      } catch (error) {
        console.error('Error creating conversation:', error);
      }
    }

    // Initialize messaging
    async function init() {
      // Only initialize if we're on the inbox page
      if (!qs('#chat-lists')) return;
      
      // Set current user ID (from Django template or data attribute)
      window.currentUserId = parseInt(document.body.dataset.userId || '0');
      
      // Only proceed if user is authenticated
      if (!window.currentUserId) return;
      
      // Setup visibility tracking for notifications
      setupVisibilityTracking();
      
      // Request notification permission
      requestNotificationPermission();
      
      // Connect to WebSocket for real-time messaging
      connectWebSocket();
      
      // Initialize image modal
      initImageModal();
      
      // Load conversations on page load
      await loadConversations('inbox');
      
      // Load request count for badge
      await loadRequestCount();
      
      // Inbox search functionality
      const inboxSearchInput = qs('#inboxSearchInput');
      if (inboxSearchInput) {
        inboxSearchInput.addEventListener('input', debounce((e) => {
          filterConversations(e.target.value);
        }, 200));
      }
      
      // Tab switching
      const messagesTab = qs('#messages-tab');
      const requestsTab = qs('#requests-tab');
      
      if (messagesTab) {
        messagesTab.addEventListener('click', async () => {
          messagesTab.classList.add('active');
          if (requestsTab) requestsTab.classList.remove('active');
          await loadConversations('inbox');
          // Reapply search filter if there's a query
          if (inboxSearchQuery) {
            filterConversations(inboxSearchQuery);
          }
        });
      }
      
      if (requestsTab) {
        requestsTab.addEventListener('click', async () => {
          requestsTab.classList.add('active');
          if (messagesTab) messagesTab.classList.remove('active');
          await loadConversations('requests');
          // Reapply search filter if there's a query
          if (inboxSearchQuery) {
            filterConversations(inboxSearchQuery);
          }
        });
      }
      
      // Accept/Reject buttons in chat view (for request prompt)
      const acceptRequestBtn = qs('#accept-request-btn');
      const rejectRequestBtn = qs('#reject-request-btn');
      
      if (acceptRequestBtn) {
        acceptRequestBtn.addEventListener('click', () => {
          if (currentConversationId) {
            handleRequestAction(currentConversationId, 'accept');
          }
        });
      }
      
      if (rejectRequestBtn) {
        rejectRequestBtn.addEventListener('click', () => {
          if (currentConversationId) {
            handleRequestAction(currentConversationId, 'reject');
          }
        });
      }
      
      // Check for initial conversation from URL (using short_id)
      const initialShortId = document.body.dataset.initialConversation;
      if (initialShortId) {
        const chatItem = qs(`[data-short-id="${initialShortId}"]`);
        if (chatItem) {
          try {
            const otherUser = JSON.parse(chatItem.dataset.otherUser);
            const convId = parseInt(chatItem.dataset.conversationId);
            const isRequest = chatItem.dataset.isRequest === 'true';
            openConversation(convId, otherUser, initialShortId, isRequest);
          } catch (e) {
            console.error('Error opening initial conversation:', e);
          }
        }
      }
      
      // Check for start_chat query parameter (from portfolio detail page)
      const urlParams = new URLSearchParams(window.location.search);
      const startChatUserId = urlParams.get('start_chat');
      if (startChatUserId) {
        // Remove the parameter from URL to clean it up
        urlParams.delete('start_chat');
        const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
        window.history.replaceState({}, '', newUrl);
        
        // Find existing conversation with this user
        const existingConversation = qsa('.chat-list-item').find(item => {
          try {
            const otherUser = JSON.parse(item.dataset.otherUser);
            return otherUser.id === parseInt(startChatUserId);
          } catch (e) {
            return false;
          }
        });
        
        if (existingConversation) {
          // Conversation exists - open it
          const conversationId = parseInt(existingConversation.dataset.conversationId);
          const shortId = existingConversation.dataset.shortId;
          const otherUser = JSON.parse(existingConversation.dataset.otherUser);
          const isRequest = existingConversation.dataset.isRequest === 'true';
          openConversation(conversationId, otherUser, shortId, isRequest);
        } else {
          // No existing conversation - fetch user info and show say-hello-section
          // so the user can select an intent
          try {
            const response = await fetch(`/api/users/${startChatUserId}/info/`, {
              credentials: 'same-origin',
            });
            
            if (response.ok) {
              const userData = await response.json();
              
              // Set the user for new chat (triggers say-hello-section flow)
              selectedUserForNewChat = {
                id: parseInt(startChatUserId),
                name: userData.name || userData.username,
                avatar: userData.avatar,
                is_online: userData.is_online,
                last_seen: userData.last_seen,
              };
              
              // Show chat-active-state with say-hello-section
              const instructionState = qs('#instruction-state');
              const chatActiveState = qs('.chat-active-state');
              const sayHelloSection = qs('.say-hello-section');
              const messageInputSection = qs('#message-input-section');
              
              if (instructionState) instructionState.style.display = 'none';
              if (chatActiveState) chatActiveState.style.display = 'flex';
              if (sayHelloSection) sayHelloSection.style.display = 'flex';
              if (messageInputSection) messageInputSection.style.display = 'none';
              
              // Mobile: show chat panel, hide list
              const listChatWindow = qs('.list_chat_window');
              const rightContent = qs('.right_content');
              if (window.innerWidth <= 991) {
                if (listChatWindow) listChatWindow.classList.add('hidden');
                if (rightContent) rightContent.classList.add('active');
              }
              
              // Update header with selected user info
              const headerAvatar = qs('.chat-header-avatar');
              const headerName = qs('.chat-header-name');
              const headerStatus = qs('#chat-header-status');
              
              if (headerAvatar) headerAvatar.src = selectedUserForNewChat.avatar || STATIC_ASSETS.defaultAvatar;
              if (headerName) headerName.textContent = selectedUserForNewChat.name;
              if (headerStatus) {
                const status = selectedUserForNewChat.is_online ? 'Online' : 
                  selectedUserForNewChat.last_seen ? `Last seen ${timeAgo(selectedUserForNewChat.last_seen)}` : '';
                headerStatus.textContent = status;
              }
            } else {
              console.error('Failed to fetch user info for start_chat');
            }
          } catch (error) {
            console.error('Error fetching user info from start_chat:', error);
          }
        }
      }
      
      // Event listeners
      function openUserSearchModal() {
        const userSearchModal = qs('#user-search-modal');
        if (!userSearchModal) return;
        userSearchModal.style.display = 'flex';
        const input = qs('#userSearchInput');
        const results = qs('#user-search-results');
        const emptyState = qs('#user-search-empty');
        const initialState = qs('#user-search-initial');
        if (input) input.value = '';
        if (results) results.innerHTML = '';
        if (emptyState) emptyState.style.display = 'none';
        if (initialState) initialState.style.display = 'flex';
        loadSuggestedUsers();
      }

      const startNewChatBtn = qs('#start-new-chat-btn');
      if (startNewChatBtn) {
        startNewChatBtn.addEventListener('click', openUserSearchModal);
      }

      const startConversationModalBtn = qs('#start-conversation-modal-btn');
      if (startConversationModalBtn) {
        startConversationModalBtn.addEventListener('click', openUserSearchModal);
      }
      
      // Back button for mobile
      const backBtn = qs('#back-btn');
      if (backBtn) {
        backBtn.addEventListener('click', () => {
          // Mobile: Hide chat window, show chat list
          const listChatWindow = qs('.list_chat_window');
          const rightContent = qs('.right_content');
          if (listChatWindow) listChatWindow.classList.remove('hidden');
          if (rightContent) rightContent.classList.remove('active');
          
          // Clear current conversation
          const instructionState = qs('#instruction-state');
          const chatActiveState = qs('.chat-active-state');
          if (instructionState) instructionState.style.display = 'flex';
          if (chatActiveState) chatActiveState.style.display = 'none';
          currentConversationId = null;
          currentOtherUser = null;
          currentIsRequest = false;
          currentShortId = null;
          
          // Update URL to remove conversation
          updateUrl(null);
        });
      }
      
      // User search input
      const userSearchInput = qs('#userSearchInput');
      if (userSearchInput) {
        userSearchInput.addEventListener('input', debounce((e) => {
          searchUsers(e.target.value);
        }, 300));
      }
      
      // Close modals
      const closeUserSearch = qs('#close-user-search');
      if (closeUserSearch) {
        closeUserSearch.addEventListener('click', () => {
          const modal = qs('#user-search-modal');
          if (modal) modal.style.display = 'none';
        });
      }
      
      // Conversation starter buttons (say-hello-section)
      qsa('.conversation-starter-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const intent = btn.dataset.type;
          if (!intent) return;
          
          // Handle new conversation (selectedUserForNewChat exists)
          if (selectedUserForNewChat) {
            createConversation(intent);
            return;
          }
          
          // Handle existing empty conversation (currentConversationId exists)
          if (currentConversationId && currentOtherUser) {
            // Update conversation intent if needed
            try {
              const response = await fetch('/api/conversations/create/', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json',
                  'X-CSRFToken': getCSRFToken(),
                },
                credentials: 'same-origin',
                body: JSON.stringify({
                  other_user_id: currentOtherUser.id,
                  intent: intent,
                }),
              });
              
              if (response.ok) {
                // Hide say-hello-section and show input
                const sayHelloSection = qs('.say-hello-section');
                const messageInputSection = qs('#message-input-section');
                const messageInput = qs('#messageInput');
                
                if (sayHelloSection) sayHelloSection.style.display = 'none';
                if (messageInputSection) messageInputSection.style.display = 'block';
                
                // Prepopulate message based on intent
                if (messageInput) {
                  const intentMessages = {
                    'portfolio-review': 'Hi!\n\nI came across your work and it really stood out.\nI’m currently refining my portfolio — sharing the link below in case you’re open to quick feedback:', 
                    'guidance': 'Hi!\n\nI’m at a point in my design career where I’m thinking about next steps.\nI’d really appreciate any perspective or advice if you’re open to sharing.',
                    'opportunities': 'Hi!\n\nI found your profile on Wall of Portfolios and really liked your work.\nI’d love to connect and explore potential opportunities if you’re open to a conversation.',
                  };
                  messageInput.value = intentMessages[intent] || '';
                  
                  // Trigger auto-grow to show all lines
                  setTimeout(() => {
                    messageInput.style.height = 'auto';
                    const scrollHeight = messageInput.scrollHeight;
                    const maxHeight = 160; // Max height in pixels
                    const newHeight = Math.min(scrollHeight, maxHeight);
                    messageInput.style.height = newHeight + 'px';
                    // Enable scrolling when content exceeds max height
                    messageInput.style.overflowY = scrollHeight > maxHeight ? 'auto' : 'hidden';
                    // Focus the input
                    messageInput.focus();
                  }, 0);
                }
              }
            } catch (error) {
              console.error('Error updating conversation intent:', error);
            }
          }
        });
      });
      
      // Message input - auto-grow textarea
      const messageInput = qs('#messageInput');
      if (messageInput) {
        // Auto-grow function
        function autoGrowTextarea() {
          messageInput.style.height = 'auto';
          const scrollHeight = messageInput.scrollHeight;
          const maxHeight = 160; // Max height in pixels
          const newHeight = Math.min(scrollHeight, maxHeight);
          messageInput.style.height = newHeight + 'px';
          // Enable scrolling when content exceeds max height
          messageInput.style.overflowY = scrollHeight > maxHeight ? 'auto' : 'hidden';
        }
        
        // Auto-grow on input
        messageInput.addEventListener('input', () => {
          autoGrowTextarea();
          clearTimeout(typingTimeout);
          updateTypingStatus(true);
          typingTimeout = setTimeout(() => {
            updateTypingStatus(false);
          }, 2000);
        });
        
        // Handle Enter vs Shift+Enter
        messageInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
            // Reset height after sending
            setTimeout(() => {
              messageInput.style.height = 'auto';
            }, 0);
          }
        });
        
        // No initial height - let it be natural
      }
      
      // Send button
      const sendBtn = qs('#sendBtn');
      if (sendBtn) {
        sendBtn.addEventListener('click', sendMessage);
      }
      
      // File input
      const fileInput = qs('#fileInput');
      if (fileInput) {
        fileInput.addEventListener('change', handleFileSelect);
      }
      
      const attachmentBtn = qs('#attachmentBtn');
      if (attachmentBtn) {
        attachmentBtn.addEventListener('click', () => {
          fileInput?.click();
        });
      }
      
      // Remove file button
      const removeFileBtn = qs('#remove-file-btn');
      if (removeFileBtn) {
        removeFileBtn.addEventListener('click', clearFilePreview);
      }
      
      
      // Reaction picker buttons
      qsa('.reaction-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const reaction = btn.dataset.reaction;
          const picker = qs('#reaction-picker');
          const messageId = picker?.dataset.messageId;
          
          if (messageId && reaction) {
            toggleReaction(messageId, reaction);
            closeReactionPicker();
          }
        });
      });
      
      // Handle page visibility for WebSocket reconnection
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
          // Page is hidden - WebSocket will handle disconnect via onclose
        } else {
          // Page is visible again - ensure WebSocket is connected
          if (!chatSocket || chatSocket.readyState !== WebSocket.OPEN) {
            connectWebSocket();
          }
        }
      });
      
      // Cleanup on page unload
      window.addEventListener('beforeunload', () => {
        disconnectWebSocket();
      });
      
      // Handle browser back/forward buttons
      window.addEventListener('popstate', async (event) => {
        if (event.state && event.state.shortId) {
          const shortId = event.state.shortId;
          const chatItem = qs(`[data-short-id="${shortId}"]`);
          if (chatItem) {
            try {
              const otherUser = JSON.parse(chatItem.dataset.otherUser);
              const convId = parseInt(chatItem.dataset.conversationId);
              const isRequest = chatItem.dataset.isRequest === 'true';
              // Don't update URL again (we're responding to URL change)
              currentConversationId = convId;
              currentOtherUser = otherUser;
              currentShortId = shortId;
              currentIsRequest = isRequest;
              await loadConversationUI(convId, otherUser);
            } catch (e) {
              console.error('Error handling popstate:', e);
            }
          }
        } else {
          // No conversation - show instruction state
          const instructionState = qs('#instruction-state');
          const chatActiveState = qs('.chat-active-state');
          if (instructionState) instructionState.style.display = 'flex';
          if (chatActiveState) chatActiveState.style.display = 'none';
          currentConversationId = null;
          currentOtherUser = null;
          currentIsRequest = false;
          currentShortId = null;
        }
      });
    }
    
    // Load conversation UI without updating URL (for popstate)
    async function loadConversationUI(conversationId, otherUser) {
      // Update UI
      const instructionState = qs('#instruction-state');
      const chatActiveState = qs('.chat-active-state');
      const sayHelloSection = qs('.say-hello-section');
      const messageInputSection = qs('#message-input-section');
      
      if (instructionState) instructionState.style.display = 'none';
      if (chatActiveState) chatActiveState.style.display = 'flex';
      // Don't set say-hello-section or message input visibility here - let loadMessages handle it based on message count
      // This ensures empty conversations show the say-hello-section
      
      // Update header
      const headerAvatar = qs('.chat-header-avatar');
      const headerName = qs('.chat-header-name');
      const headerStatus = qs('#chat-header-status');
      
      if (headerAvatar) headerAvatar.src = otherUser.avatar || STATIC_ASSETS.defaultAvatar;
      if (headerName) headerName.textContent = otherUser.name;
      if (headerStatus) {
        const status = otherUser.is_online ? 'Online' : 
          otherUser.last_seen ? `Last seen ${timeAgo(otherUser.last_seen)}` : '';
        headerStatus.textContent = status;
      }
      
      // Mark active in list and clear unread badge
      qsa('.chat-list-item').forEach(item => item.classList.remove('active'));
      const activeItem = qs(`[data-conversation-id="${conversationId}"]`);
      if (activeItem) {
        activeItem.classList.add('active');
        const unreadBadge = activeItem.querySelector('.unread-badge');
        if (unreadBadge) unreadBadge.remove();
      }
      
      // Load messages (force scroll when opening conversation)
      await loadMessages(conversationId, true);
      
      // Join conversation via WebSocket
      joinConversation(conversationId);
      
      // Mark messages as read
      sendWebSocketMessage({
        type: 'mark_read',
        conversation_id: conversationId
      });
    }

    window.MessagingApp = { init };
  })();
