// =================== MODALS ===================
// Login and Search modals

(() => {
  // Import core utilities
  const { qs, qsa, show, hide, setSuppression, closeFiltersModal, debounce, escapeHtml, getCookie } = window.CoreUtils || {};

  // ===== LOGIN MODAL =====
  function setNextOnModal() {
    const m = qs(".loginmodal"); if (!m) return;
    const next = encodeURIComponent(location.pathname + location.search + location.hash);
    // update all links carrying next=
    qsa('a[href*="next="]', m).forEach((a) => {
      try {
        const url = new URL(a.getAttribute("href"), location.origin);
        url.searchParams.set("next", next);
        a.setAttribute("href", url.pathname + url.search);
      } catch(_) {}
    });
    // update hidden input
    const nextInput = qs('input[name="next"]', m);
    if (nextInput) nextInput.value = decodeURIComponent(next);
  }

  window.openLoginModal = function () {
    setSuppression('_suppressFilterOpen', 800);
    closeFiltersModal();
    const m = qs(".loginmodal");
    if (!m) {
      const next = encodeURIComponent(location.pathname + location.search + location.hash);
      location.href = `/accounts/login?next=${next}`;
      return;
    }
    setNextOnModal();
    m.style.display = "flex"; // your modal uses flex
    document.documentElement.classList.add("no-scroll");
  };

  window.closeLoginModal = function (e) {
    if (e) e.preventDefault();
    const m = qs(".loginmodal");
    if (!m) return;
    setSuppression('_suppressFilterOpen', 800);
    m.style.display = "none";
    document.documentElement.classList.remove("no-scroll");
    // If a non-logged-in user landed on a filtered URL and chose to close the login,
    // reset to "All" so they can see public results.
    if (document.body?.dataset?.auth !== "1" && typeof hasActiveFilterParams === 'function' && hasActiveFilterParams()) {
      if (typeof clearFiltersToAll === 'function') clearFiltersToAll();
    }
    closeFiltersModal();
  };

  // search modal close (kept to satisfy any inline onclick="closeSearchModal()")
  window.closeSearchModal = function (e) {
    if (e) e.preventDefault();
    const searchModal = qs(".search-modal");
    if (searchModal) searchModal.style.display = "none";
    // also close login if open
    window.closeLoginModal();
    // optional cleanup for search UI (safe no-ops if elements absent)
    const input = qs("#searchInput");
    if (input) input.value = "";
    ["#emptyState","#loadingState","#noResultsState"].forEach((id)=>hide(qs(id)));
    const suggestions = qs("#suggestions");
    if (suggestions) qsa(".search-item", suggestions).forEach((c)=>c.remove());
  };

  function initLoginModal() {
    const m = qs(".loginmodal"); if (!m) return;
    // ensure hidden initially (authoring time can be flex)
    m.style.display = "none";

    // backdrop click closes only when clicking backdrop (not inner content)
    m.addEventListener("click", (ev) => { if (ev.target === m) window.closeLoginModal(); });

    // Esc to close
    document.addEventListener("keydown", (e) => { if (e.key === "Escape") window.closeLoginModal(); });

    // Any element with .loginmodal-close should close it (in case you add such buttons)
    document.addEventListener("click", (e) => {
      const btn = e.target.closest(".loginmodal-close");
      if (btn) window.closeLoginModal(e);
    });
  }

  // ===== SEARCH MODAL =====
  async function fetchDesigners(query) {
    const headers = {};
    if (window.SUPABASE_KEY) {
      headers.apikey = window.SUPABASE_KEY;
      headers.Authorization = `Bearer ${window.SUPABASE_KEY}`;
    }
    const res = await fetch(`/fetch_designers/?query=${encodeURIComponent(query)}`, { headers });
    return res.json();
  }

  async function logSearch(query) {
    try {
      await fetch(`save_search_query/`, {
        method: "POST",
        headers: { 
          "Content-Type": "application/json",
          "X-CSRFToken": getCookie("csrftoken") || "",
        },
        body: JSON.stringify({ query, timestamp: new Date().toISOString() }),
        credentials: "same-origin",
      });
    } catch (_) {}
  }

  // Helper function to sort by exact match
  function sortByExactMatch(items, query, getTextFn) {
    if (!items || items.length === 0) return items;
    const queryLower = query.toLowerCase();
    return [...items].sort((a, b) => {
      const aText = getTextFn(a).toLowerCase();
      const bText = getTextFn(b).toLowerCase();
      
      // Exact match (equals or starts with query + space)
      const aExact = aText === queryLower || aText.startsWith(queryLower + ' ');
      const bExact = bText === queryLower || bText.startsWith(queryLower + ' ');
      
      // Exact matches come first
      if (aExact && !bExact) return -1;
      if (!aExact && bExact) return 1;
      
      // If both exact or both partial, sort alphabetically
      return aText.localeCompare(bText);
    });
  }

  async function handleSearchInput() {
    const input        = qs("#searchInput");
    const suggestions  = qs("#suggestions");
    const emptyState   = qs("#emptyState");
    const loadingState = qs("#loadingState");
    const noResults    = qs("#noResultsState");
    const query = (input?.value || "").trim();

    hide(emptyState); hide(loadingState); hide(noResults);
    
    // Clear only search result items, not the state elements
    if (suggestions) {
      const searchItems = suggestions.querySelectorAll('.search-item');
      searchItems.forEach(item => item.remove());
    }

    if (!query) { show(emptyState); return; }

    show(loadingState);
    try {
      await logSearch(query);
      const data = await fetchDesigners(query);
      
      let designers = data.designers || [];
      let companies = data.companies || [];
      let roles = data.roles || [];
      let skills = data.skills || [];
      
      // Sort by exact match (backend already sorts, but this ensures frontend consistency)
      companies = sortByExactMatch(companies, query, (c) => c.name);
      designers = sortByExactMatch(designers, query, (d) => d.name);
      roles = sortByExactMatch(roles, query, (r) => r);
      skills = sortByExactMatch(skills, query, (s) => s);
      
      hide(loadingState);
      
      const hasResults = designers.length > 0 || companies.length > 0 || 
                        roles.length > 0 || skills.length > 0;
      
      if (!hasResults) { 
        show(noResults); 
        return; 
      }

      // Helper to create search item
      const createSearchItem = (href, icon, title, subtitle, category) => {
        const item = document.createElement("a");
        item.href = href;
        item.target = "_blank";
        item.className = "search-item";
        item.style.cssText = "display:flex;align-items:center;gap:12px;padding:12px 0;text-decoration:none;color:#000;";
        
        const iconHtml = icon ? 
          `<div style="padding:0px;margin:0px;border-radius:50%;border:1px solid #e7e7e9;width:56px;height:56px;overflow:hidden;flex-shrink:0;">
            <img src="${escapeHtml(icon)}" style="width:56px;height:56px;object-fit:cover;display:block;">
          </div>` : 
          `<div style="padding:0px;margin:0px;border-radius:50%;border:1px solid #e7e7e9;width:56px;height:56px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M10 2L12.5 7.5L18 8.5L14 12.5L14.5 18L10 15.5L5.5 18L6 12.5L2 8.5L7.5 7.5L10 2Z" fill="#666"/>
            </svg>
          </div>`;
        
        item.innerHTML = `
          ${iconHtml}
          <div style="flex:1;display:flex;flex-direction:column;gap:4px;">
            <div class="llg text-grey300 shrink">${escapeHtml(title)}</div>
            ${subtitle ? `<div class="lm3 text-grey200">${escapeHtml(subtitle)}</div>` : ''}
            <div class="lm3 text-grey200">${category}</div>
          </div>
        `;
        return item;
      };

      // Companies section (first)
      if (companies.length > 0) {
        companies.forEach((c) => {
          const item = createSearchItem(
            `/companies/${c.slug}/`,
            c.logoUrl,
            c.name,
            null,
            "Company"
          );
          suggestions.appendChild(item);
        });
      }

      // Designers section (second)
      if (designers.length > 0) {
        designers.forEach((d) => {
          const workExp = Array.isArray(d.workExp) ? d.workExp : [];
          const currentCompany = workExp[0] || '';
          const previousCompanies = workExp.slice(1);
          const trail = previousCompanies.length ? `. Previously at ${previousCompanies.join(" & ")}` : "";
          const roleDisplay = d.role && currentCompany ? `${d.role} @${currentCompany}${trail}` : d.role || "";
          
          const item = document.createElement("a");
          item.href = `/portfolios/${d.slug}/`;
          item.target = "_blank";
          item.className = "search-item";
          item.style.cssText = "display:flex;align-items:center;gap:12px;padding:12px 0;text-decoration:none;color:#000;";
          
          item.innerHTML = `
            <div style="padding:0px;margin:0px;border-radius:50%;border:1px solid #e7e7e9;width:56px;height:56px;overflow:hidden;flex-shrink:0;">
              <img src="${escapeHtml(d.designerUrl)}" style="width:56px;height:56px;object-fit:cover;display:block;">
            </div>
            <div style="flex:1;display:flex;flex-direction:column;gap:4px;">
              <div class="llg text-grey300 shrink">${escapeHtml(d.name)}</div>
              ${roleDisplay ? `<div class="lm3 text-grey200">${escapeHtml(roleDisplay)}</div>` : ''}
            </div>
          `;
          suggestions.appendChild(item);
        });
      }

      // Get static URLs from global variables or fallback
      const roleIconUrl = (window.STATIC_URLS && window.STATIC_URLS['role-icon']) || (window.STATIC_URL + 'images/role.svg') || '/static/images/role.svg';
      const skillsIconUrl = (window.STATIC_URLS && window.STATIC_URLS['skills-icon']) || (window.STATIC_URL + 'images/skills.svg') || '/static/images/skills.svg';

      // Roles section (third)
      if (roles.length > 0) {
        roles.forEach((role) => {
          const item = createSearchItem(
            `/search/role/${encodeURIComponent(role)}/`,
            roleIconUrl,
            role,
            null,
            "Role"
          );
          suggestions.appendChild(item);
        });
      }

      // Skills section (fourth)
      if (skills.length > 0) {
        skills.forEach((skill) => {
          // Truncate skill text to 24 characters
          const skillDisplay = skill.length > 24 ? skill.substring(0, 24) + '...' : skill;
          const item = createSearchItem(
            `/search/skill/${encodeURIComponent(skill)}/`,
            skillsIconUrl,
            skillDisplay,
            null,
            "Skills"
          );
          suggestions.appendChild(item);
        });
      }
    } catch (e) {
      hide(loadingState); 
      show(noResults); 
      console.error("Search error:", e);
    }
  }

  function initSearchModal() {
    const { isLoggedIn } = window.CoreUtils || {};
    const triggers    = qsa(".search-trigger");
    const searchModal = qs(".search-modal");
    const loginM      = qs(".loginmodal");
    if (!triggers.length) return;

    const openSearch = () => {
      if (!isLoggedIn()) { window.openLoginModal(); return; }
      if (!searchModal) return;
      show(searchModal, "flex");
      const input = qs("#searchInput");
      if (input) {
        input.value = "";
        const suggestions = qs("#suggestions");
        if (suggestions) qsa(".search-item", suggestions).forEach((c) => c.remove());
        show(qs("#emptyState")); hide(qs("#loadingState")); hide(qs("#noResultsState"));
        input.focus();
      }
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", (e) => { e.preventDefault(); e.stopPropagation(); openSearch(); }, true);
    });

    // ESC to close either
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") window.closeSearchModal();
    });

    const input = qs("#searchInput");
    if (input) input.addEventListener("input", debounce(handleSearchInput, 300));

    // in case you need a dedicated closer for login modal from search UI
    if (loginM) qsa(".loginmodal .dialougeclose").forEach((x)=>x.addEventListener("click", window.closeLoginModal));
  }

  // Export initialization function
  window.Modals = {
    init: () => {
      initLoginModal();
      initSearchModal();
    }
  };
})();

