  // ===== BOOT =====
  onReady(() => {
    // Initialize modules (loaded before this script)
    if (window.Modals && window.Modals.init) window.Modals.init();
    if (window.Auth && window.Auth.init) window.Auth.init();
    if (window.MessagingApp && window.MessagingApp.init) window.MessagingApp.init();

    // Initialize page-specific features
    initProfileDropdown();
    initNotificationDropdown();
    initMobileNav();
    
    // Refresh message badge count and connect navbar WebSocket (for logged-in users)
    if (isLoggedIn && isLoggedIn()) {
      refreshMessageBadge();
      // Connect navbar WebSocket for real-time badge updates
      connectNavbarWebSocket();
    }

    initPtmStoryToggle();
    initShowMoreLess();
    initFinsweetCountBubble();
    initCustomEmptyStateObserver();
    initInfiniteList();
    initBookmarkClicks();

    // Initialize sidebar collapse toggle
    // initCollapseToggle();

    // Auto-prompt login if someone lands on a filtered URL (optional)
    if (isLoggedIn && !isLoggedIn() && window.Auth && window.Auth.hasActiveFilterParams && window.Auth.hasActiveFilterParams()) {
      if (window.openLoginModal) window.openLoginModal();
    }
  });
})();
