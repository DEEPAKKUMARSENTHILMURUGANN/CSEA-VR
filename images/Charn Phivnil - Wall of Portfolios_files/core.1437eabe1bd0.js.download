// =================== CORE HELPERS & UTILITIES ===================
// Shared utilities and helper functions used across modules

// ---- tiny helpers
function setSuppression(flag, ms = 800) {
  window[flag] = true;
  setTimeout(() => (window[flag] = false), ms);
}

function closeFiltersModal() {
  const guesses = [
    '.filters-modal',
    '#filtersPane',
    '.w-dropdown-list.is--filters',
    '[data-filters-modal="true"]'
  ];
  guesses.forEach(sel => {
    const el = document.querySelector(sel);
    if (!el) return;
    // common ways Webflow/vanilla toggles visibility
    el.style.display = 'none';
    el.classList.remove('show','open','is-open','w--open');
    // if it's a dropdown from a known toggle
    const parent = el.closest('.w-dropdown');
    if (parent) parent.classList.remove('w--open');
  });
}

const onReady = (fn) =>
  document.readyState !== "loading" ? fn() : document.addEventListener("DOMContentLoaded", fn);

const qs  = (sel, root = document) => root.querySelector(sel);
const qsa = (sel, root = document) => Array.from(root.querySelectorAll(sel));
const show = (el, display = "block") => el && (el.style.display = display);
const hide = (el) => el && (el.style.display = "none");
const toggle = (el, cls) => el && el.classList.toggle(cls);
const remove = (el, cls) => el && el.classList.remove(cls);
const debounce = (fn, delay = 300) => { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), delay); }; };

// ===== GLOBAL STATE =====
const isLoggedIn = () => document.body?.dataset?.auth === "1";
const BOOKMARK_TOGGLE_URL = document.body?.dataset?.toggleUrl || "/api/bookmarks/toggle/";
const CASESTUDY_BOOKMARK_TOGGLE_URL = document.body?.dataset?.casestudyToggleUrl || "/api/bookmarks/toggle/casestudy/";

// ===== UTILITY FUNCTIONS =====
function getCookie(name){
  const m = document.cookie.match('(^|;)\\s*' + name + '\\s*=\\s*([^;]+)');
  return m ? m.pop() : '';
}

function timeAgo(iso){
  const d=new Date(iso), s=Math.floor((Date.now()-d)/1000);
  const t=[[31536000,'year'],[2592000,'month'],[604800,'week'],[86400,'day'],[3600,'hour'],[60,'minute']];
  for(const [sec,label] of t){ if(s>=sec){const v=Math.floor(s/sec); return `${v} ${label}${v>1?'s':''} ago`}}
  return 'just now';
}

function timeAgoShort(iso){
  const d=new Date(iso), s=Math.floor((Date.now()-d)/1000);
  const t=[[31536000,'y'],[2592000,'mo'],[604800,'w'],[86400,'d'],[3600,'h'],[60,'m']];
  for(const [sec,label] of t){ if(s>=sec){const v=Math.floor(s/sec); return `${v} ${label}`}}
  return 'now';
}

function escapeHtml(str){ return (str||'').replace(/[&<>"']/g, m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m])); }

// Export to window for use in other modules
window.CoreUtils = {
  setSuppression,
  closeFiltersModal,
  onReady,
  qs,
  qsa,
  show,
  hide,
  toggle,
  remove,
  debounce,
  isLoggedIn,
  getCookie,
  timeAgo,
  timeAgoShort,
  escapeHtml,
  BOOKMARK_TOGGLE_URL,
  CASESTUDY_BOOKMARK_TOGGLE_URL
};

